PORT=9090
DATA_DIR=./data
CONFIG_DIR=./config
# ENABLE_UPLOAD_FORM=true
# JWT_SECRET=

# Global token that grants upload, delete, and download access across all projects.
# Acts as a superuser key — accepted anywhere a per-project token would be.
# Does NOT change auth requirements of individual projects (open projects stay open).
# GLOBAL_TOKEN=

# Docker: UID/GID of the host user for correct file ownership in mounted volumes.
# Run `id -u` and `id -g` to find your values.
# PUID=1000
# PGID=1000

# CDN integration (optional). Set CDN_PROVIDER to enable.
# CDN_PROVIDER=cloudflare
# CDN_CACHE_PURGE_URL_PREFIX=https://cdn.example.com
# CDN_CACHE_MAX_AGE=60
# CDN_CACHE_S_MAXAGE=604800
# CDN_STALE_WHILE_REVALIDATE=86400

# Cloudflare-specific (required when CDN_PROVIDER=cloudflare)
# CF_ZONE_ID=
# CF_API_TOKEN=
