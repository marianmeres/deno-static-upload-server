{
  "name": "@marianmeres/deno-static-upload-server",
  "version": "1.2.9",
  "exports": {
    ".": "./src/cli.ts",
    "./server": "./src/server.ts"
  },
  "tasks": {
    "dev": "deno run --watch -A example/main.ts",
    "example": "deno run --env=.env.example -A example/main.ts",
    "test": "deno test -A",
    "release": "deno run -A jsr:@marianmeres/deno-release",
    "publish": "deno publish",
    "rp": "deno task release -y && deno task publish",
    "rpm": "deno task release minor -y && deno task publish",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:upgrade": "docker compose up -d --force-recreate --pull always",
    "docker:restart": "docker compose down && docker compose up -d --force-recreate",
    "docker:rebuild": "docker compose down && docker compose build && docker compose up -d --force-recreate",
    "docker:logs": "docker compose logs -f",
    "deploy": "bash deploy.sh"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/http": "jsr:@std/http@^1.0.25",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 90,
    "indentWidth": 4,
    "proseWrap": "preserve"
  }
}
